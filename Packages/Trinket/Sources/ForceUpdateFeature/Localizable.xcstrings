{
  "sourceLanguage": "en",
  "strings": {
    "... Oh? ! ! Looks like Trinket...! \nPlease update to the latest version.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "...おや？！Trinketのようすが...！\n最新バージョンへのアップデートをお願いします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "...오? ! ! Trinket처럼 보이네요...! \n최신 버전으로 업데이트해 주세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "... Oh ? ! ! On dirait Trinket...! \nVeuillez mettre à jour vers la dernière version."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "... Och? ! ! Wygląda na Trinket...! \nProszę zaktualizować do najnowszej wersji."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "... Ồ? ! ! Trông giống như Trinket...! \nVui lòng cập nhật lên phiên bản mới nhất."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "... ¡Oh? ! ! Parece Trinket...! \nPor favor, actualiza a la última versión."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "... Oh? ! ! Parece o Trinket...! \nPor favor, atualize para a versão mais recente."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "... أوه؟ ! ! يبدو مثل Trinket...! \nيرجى التحديث إلى أحدث إصدار."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "... Oh? ! ! Sepertinya Trinket...! \nSilakan perbarui ke versi terbaru."
          }
        }
      }
    },

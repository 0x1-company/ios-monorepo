          }
        }
      }
    },
    "This **cannot** be undone or recovered.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これを元に戻したり、回復したりすることは**出来ません**。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이것은 **되돌릴 수** 없거나 복구할 수 없습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela **ne peut pas** être annulé ou récupéré."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tego **nie można** cofnąć ani odzyskać."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điều này **không thể** được hoàn tác hoặc khôi phục."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto **no** se puede deshacer ni recuperar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso **não** pode ser desfeito ou recuperado."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن **التراجع** عن هذا أو استعادته."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini **tidak dapat** dibatalkan atau dipulihkan."
          }
        }
      }
    }
  },
  "version": "1.0"
}

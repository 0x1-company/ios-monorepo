{
  "sourceLanguage": "en",
  "strings": {
    "Are you sure you want to delete your account?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当にアカウントを削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말로 계정을 삭제하시겠습니까?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer votre compte ?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć swoje konto?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn xóa tài khoản của mình không?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que deseas eliminar tu cuenta?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir sua conta?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد من أنك تريد حذف حسابك؟"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin menghapus akun Anda?"
          }
        }
      }
    },
    "Delete Account": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 삭제"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer le compte"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń konto"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa tài khoản"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar cuenta"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir conta"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حذف الحساب"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapus Akun"
          }
        }
      }
    },
    "Not Now": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今はしない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금은 아니오"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas maintenant"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie teraz"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không phải bây giờ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No ahora"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agora não"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ليس الآن"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak Sekarang"
          }
        }
      }
    },
    "Other Reason": {
      "localizations": {
        "ja": {
          "stringUnit": {

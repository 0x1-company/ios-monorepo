{
  "sourceLanguage": "en",
  "strings": {
    "Are you sure you want to unmatch?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当にマッチ解除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말로 매칭을 해제하시겠습니까?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn hủy ghép đôi không?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir annuler la correspondance ?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz rozwiązać dopasowanie?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que quieres deshacer el emparejamiento?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja desfazer a correspondência?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد فك المطابقة؟"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin membatalkan kecocokan?"
          }
        }
      }
    },

    "I'm sending you an invite code [%@] to unlock %@ PRO for free (worth %@).\n%@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%3$@分の%2$@ PROが無料になる招待コード【%1$@】を贈りました！🎁\n\n%2$@ PROになると…\n■ 誰にLikeされているかを見れる\n\n「%2$@」ダウンロードしてね！🤞🏻\n%4$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%3$@ 가치의 %2$@ PRO를 무료로 잠금 해제할 초대 코드 [%1$@]를 보냅니다.\n%4$@"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tôi đang gửi cho bạn mã mời [%1$@] để mở khóa %2$@ PRO miễn phí (trị giá %3$@).\n%4$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je vous envoie un code d'invitation [%1$@] pour débloquer %2$@ PRO gratuitement (d'une valeur de %3$@).\n%4$@"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyłam ci kod zaproszenia [%1$@], aby odblokować %2$@ PRO za darmo (o wartości %3$@).\n%4$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te estoy enviando un código de invitación [%1$@] para desbloquear %2$@ PRO gratis (valorado en %3$@).\n%4$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estou enviando um código de convite [%1$@] para desbloquear %2$@ PRO gratuitamente (no valor de %3$@).\n%4$@"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أرسل لك رمز الدعوة [%1$@] لفتح %2$@ PRO مجانًا (بقيمة %3$@).\n%4$@"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saya mengirimkan Anda kode undangan [%1$@] untuk membuka %@ PRO secara gratis (senilai %3$@).\n%4$@"
          }
        }
      }
    }

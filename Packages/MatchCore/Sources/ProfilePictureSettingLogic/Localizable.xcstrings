    "Please select at least 3 saved photos.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存した写真を3枚以上選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 사진을 최소 3장 선택하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez sélectionner au moins 3 photos enregistrées."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Proszę wybrać co najmniej 3 zapisane zdjęcia."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng chọn ít nhất 3 ảnh đã lưu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, selecciona al menos 3 fotos guardadas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, selecione pelo menos 3 fotos salvas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى تحديد ما لا يقل عن 3 صور محفوظة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Silakan pilih minimal 3 foto yang tersimpan."
          }
        }
      }
    },

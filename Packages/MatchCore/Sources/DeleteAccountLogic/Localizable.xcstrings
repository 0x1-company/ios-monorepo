{
  "sourceLanguage": "en",
  "strings": {
    "Account deletion failed.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント削除に失敗しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 삭제에 실패했습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La suppression du compte a échoué."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunięcie konta nie powiodło się."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa tài khoản thất bại."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falló la eliminación de la cuenta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao excluir a conta."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل حذف الحساب."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Penghapusan akun gagal."
          }
        }
      }
    },
    "Are you sure you want to delete your account?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本当にアカウントを削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정을 삭제하시겠습니까?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer votre compte ?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć swoje konto?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc chắn muốn xóa tài khoản của mình không?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que quieres eliminar tu cuenta?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir sua conta?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد حذف حسابك؟"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin menghapus akun Anda?"
          }
        }
      }
    },

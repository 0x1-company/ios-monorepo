    "I don't know how to use it": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使い方が分からない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용 방법을 모르겠어요"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne sais pas comment l'utiliser"
          }
        },
        "pl": {
